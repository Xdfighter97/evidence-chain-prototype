# Evidence Chain Prototype - Environment Configuration
# Copy this file to .env and update values as needed
# NEVER commit .env to version control!

# ─────────────────────────────────────────────────────────────────────────────
# ENCRYPTION KEY (REQUIRED)
# ─────────────────────────────────────────────────────────────────────────────
# 32-byte key, base64-encoded. Generate with:
#   python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
# Or let run_pipeline.ps1 generate one automatically.
# EVIDENCE_KEY_B64=

# ─────────────────────────────────────────────────────────────────────────────
# ETHEREUM / GANACHE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
# Private key for signing transactions (include 0x prefix)
# Default Ganache accounts (use for local testing ONLY):
#   Account 0: 0x4f3edf983ac636a65a842ce7c78d9aa706d3b113bce9c46f30d7d21715b23b1d
#   Account 1: 0x6cbed15c793ce57650b9877cf6fa156fbef513c4e6134f022a85b1ffdd59b2a1
ETH_PRIVATE_KEY=0x4f3edf983ac636a65a842ce7c78d9aa706d3b113bce9c46f30d7d21715b23b1d

# ─────────────────────────────────────────────────────────────────────────────
# PIPELINE OPTIONS
# ─────────────────────────────────────────────────────────────────────────────
# Set to 1 to anchor hashes on-chain, 0 for local-only
ANCHOR_ONCHAIN=1

# Set to 1 to verify against blockchain, 0 for local-only
VERIFY_ONCHAIN=1

# Test/case identifier (auto-generated if not set)
# TEST_ID=CASE2026-001-RUN001
